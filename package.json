{
  "name": "omanote",
  "private": true,
  "workspaces": [
    "packages/*",
    "extension"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:html": "node scripts/generate-docs-html.mjs",
    "audit:colors": "node scripts/audit-colors.mjs",
    "audit:design-tokens": "node scripts/audit-design-tokens.mjs",
    "ci:design-system": "npm run audit:design-tokens && npm run typecheck",
    "desktop": "npm --prefix apps/desktop run dev",
    "desktop:build": "npm --prefix apps/desktop run build",
    "desktop:build:linux": "bash apps/desktop/docker-builder/build-linux.sh",
    "mobile": "npm --prefix apps/mobile run start",
    "mobile:android": "npm --prefix apps/mobile run android"
  },
  "dependencies": {
    "@clerk/react": "^6.1.3",
    "@omanote/shared": "workspace:*",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@vercel/analytics": "^2.0.1",
    "chrono-node": "^2.7.7",
    "clsx": "^2.1.1",
    "convex": "^1.41.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "dompurify": "^3.4.9",
    "emojilib": "^4.0.3",
    "fast-xml-parser": "^5.8.0",
    "lucide-react": "^0.475.0",
    "react-helmet-async": "^3.0.0",
    "react": "^18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^2.6.0",
    "tiptap-markdown": "^0.9.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "convex-test": "^0.0.53",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.1.0",
    "vitest": "^4.1.5"
  }
}
