{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "omanote",
  "version": "0.24.0",
  "identifier": "com.iambishistha.omanote",
  "build": {
    "beforeDevCommand": "npm --prefix ../.. run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../.. run build",
    "frontendDist": "../../../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["omanote"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFRjVDODYwNDY4MzZBNTEKUldSUmFvTkdZTWoxSHVuTE02NXBYbTRFSVJ4aWduSEdHSStncDdocytzODlGYkNPZnNtSEJhcE8K",
      "endpoints": [
        "https://github.com/thehumanx/omanote-releases/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
